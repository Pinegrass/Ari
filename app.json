{
  "expo": {
    "name": "Ari",
    "slug": "ari",
    "owner": "pinegrass-tech",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "ari",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#061313"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pinegrass.ari",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Ari uses Face ID to secure your app access.",
        "NSUserNotificationUsageDescription": "Ari sends you daily reminders and budget alerts.",
        "NSPhotoLibraryUsageDescription": "Ari needs access to your photos so you can share receipt images into Ari to log expenses."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#061313"
      },
      "package": "com.pinegrass.ari",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#061313",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "pinegrass",
          "project": "ari"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Ari needs your microphone to log expenses by voice.",
          "speechRecognitionPermission": "Ari needs speech recognition to turn your voice into transactions."
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      [
        "expo-share-intent",
        {
          "androidIntentFilters": ["text/*"]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "AriSpentToday",
              "label": "Ari — Spent today",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 1,
              "description": "Today's spend and this month's budget ring",
              "previewImage": "./assets/adaptive-icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/ae18eabf-124f-4b0a-a09e-a2a40dfb473b"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "extra": {
      "eas": {
        "projectId": "ae18eabf-124f-4b0a-a09e-a2a40dfb473b"
      }
    }
  }
}